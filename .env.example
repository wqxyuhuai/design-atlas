# Notion Effect Inbox
# Create a Notion internal integration, share the Effect Inbox database with it,
# then copy the token into .env.local or your shell environment.
NOTION_TOKEN=secret_xxx

# User-provided Effect Inbox database id.
NOTION_EFFECT_INBOX_DATABASE_ID=147bb625951e479d9db9e8be316622ee

# Optional. If omitted, scripts resolve the first data source from the database.
NOTION_EFFECT_INBOX_DATA_SOURCE_ID=

# Optional. Keep the default unless the sync spec is updated.
NOTION_API_VERSION=2026-03-11
